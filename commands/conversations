#!/usr/bin/env -S uv run python
"""
commands/conversations [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session]

Lists the dialogues/groups/channels.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs
from methods.conversations import list_conversations


async def main() -> None:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    args = parser.parse_args()

    for line in await list_conversations(**client_kwargs(args)):
        print(line)


if __name__ == "__main__":
    asyncio.run(main())
