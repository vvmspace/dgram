#!/usr/bin/env -S uv run python
"""
commands/folder [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session] <id|"Title">

Lists the chats within the given folder, resolving each included peer to
its username or id (excluded peers are shown with a leading minus sign).
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs
from methods.folder import list_folder_chats


async def main() -> int:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    parser.add_argument("folder", help="Folder id or exact title")
    args = parser.parse_args()

    try:
        lines = await list_folder_chats(args.folder, **client_kwargs(args))
    except ValueError as exc:
        print(exc, file=sys.stderr)
        return 1

    for line in lines:
        print(line)
    return 0


if __name__ == "__main__":
    sys.exit(asyncio.run(main()))
