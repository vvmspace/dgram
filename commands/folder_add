#!/usr/bin/env -S uv run python
"""
commands/folder_add [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session] <id|"Title"> @chat

Adds the given chat to the folder's list, dropping it from the exclusion
list first, should it have lingered there.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs
from methods.folder_add import add_to_folder


async def main() -> int:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    parser.add_argument("folder", help="Folder id or exact title")
    parser.add_argument("chat", help="@user/@group/@me/conversation_id to add")
    args = parser.parse_args()

    try:
        await add_to_folder(args.folder, args.chat, **client_kwargs(args))
    except ValueError as exc:
        print(exc, file=sys.stderr)
        return 1

    print(f"Added {args.chat} to folder {args.folder!r}")
    return 0


if __name__ == "__main__":
    sys.exit(asyncio.run(main()))
