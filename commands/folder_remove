#!/usr/bin/env -S uv run python
"""
commands/folder_remove [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session] <id|"Title"> @chat

Removes the given chat from the folder's list (whether it was present
amongst the included or the excluded peers).
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs
from methods.folder_remove import remove_from_folder


async def main() -> int:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    parser.add_argument("folder", help="Folder id or exact title")
    parser.add_argument("chat", help="@user/@group/@me/conversation_id to remove")
    args = parser.parse_args()

    try:
        removed = await remove_from_folder(args.folder, args.chat, **client_kwargs(args))
    except ValueError as exc:
        print(exc, file=sys.stderr)
        return 1

    if not removed:
        print(f"{args.chat} was not in folder {args.folder!r}", file=sys.stderr)
        return 1

    print(f"Removed {args.chat} from folder {args.folder!r}")
    return 0


if __name__ == "__main__":
    sys.exit(asyncio.run(main()))
