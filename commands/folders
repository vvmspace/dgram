#!/usr/bin/env -S uv run python
"""
commands/folders [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session]

Lists every chat folder, showing its id, title, and how many chats it
explicitly includes and excludes.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs
from methods.folders import list_folders


async def main() -> None:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    args = parser.parse_args()

    for line in await list_folders(**client_kwargs(args)):
        print(line)


if __name__ == "__main__":
    asyncio.run(main())
