#!/usr/bin/env -S uv run python
"""
commands/group_create [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session] "Group name" @gr0upUs3rnam3

Creates a public supergroup with the given title, then assigns it the
public username.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs
from methods.group_create import create_group


async def main() -> None:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    parser.add_argument("title", help="Group title")
    parser.add_argument("username", help="Public @username for the group")
    args = parser.parse_args()

    channel, username = await create_group(args.title, args.username, **client_kwargs(args))
    print(f"Created group {args.title!r} (id={channel.id}), @{username}")


if __name__ == "__main__":
    asyncio.run(main())
