#!/usr/bin/env -S uv run python
"""
commands/group_delete [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session] @gr0upUs3rnam3

Deletes the given group/channel.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs, emit
from methods.group_delete import delete_group


async def main() -> None:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    parser.add_argument("group", help="@group or the id of the group/channel")
    args = parser.parse_args()

    result = await delete_group(args.group, **client_kwargs(args))
    emit(result, args.json_path, lambda data: print(f"Deleted group {data['group']}"))


if __name__ == "__main__":
    asyncio.run(main())
