#!/usr/bin/env -S uv run python
"""
commands/group_delete path/to/tdata @gr0upUs3rnam3

Connects via libs/dgram and deletes the given group/channel.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from telethon.tl.functions.channels import DeleteChannelRequest

from libs.dgram import get_client, resolve_target


async def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("tdata_path", help="Path to the tdata folder")
    parser.add_argument("group", help="@group or the id of the group/channel")
    args = parser.parse_args()

    client = await get_client(args.tdata_path)
    try:
        entity = await client.get_entity(resolve_target(args.group))
        await client(DeleteChannelRequest(entity))
        print(f"Deleted group {args.group}")
    finally:
        await client.disconnect()


if __name__ == "__main__":
    asyncio.run(main())
