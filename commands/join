#!/usr/bin/env -S uv run python
"""
commands/join [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session] @group

Joins the given group/channel. Accepts a @username, a public t.me/... link,
or an invite link (t.me/+hash or t.me/joinchat/hash).
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs, emit
from methods.join import join


async def main() -> None:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    parser.add_argument("group", help="@group, a t.me/... link, or an invite link")
    args = parser.parse_args()

    result = await join(args.group, **client_kwargs(args))
    emit(result, args.json_path, lambda data: print(f"Successfully joined {data['group']}"))


if __name__ == "__main__":
    asyncio.run(main())
