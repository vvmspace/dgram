#!/usr/bin/env -S uv run python
"""
commands/leave [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session] @group

Leaves the given group/channel.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs, emit
from methods.leave import leave


async def main() -> None:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    parser.add_argument("group", help="@group or the id of the group/channel")
    args = parser.parse_args()

    result = await leave(args.group, **client_kwargs(args))
    emit(result, args.json_path, lambda data: print(f"Left {data['group']}"))


if __name__ == "__main__":
    asyncio.run(main())
