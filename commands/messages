#!/usr/bin/env -S uv run python
"""
commands/messages [-p tdata/--path-to-tdata=tdata] [--session=.session] [-l 20/--length=20] [-c ALL/--conversation_id=ALL] [-s ASC | --sort ASC]

Prints the most recent length messages (including outgoing ones) within
dialogue conversation_id, or (when ALL/left unspecified) the length most
recent messages across every dialogue. By default the oldest are shown
first (ASC); -s/--sort DESC shows the newest first.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs
from methods.messages import get_messages


async def main() -> int:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser, session_short=None)  # -s is taken by --sort below
    parser.add_argument("-l", "--length", type=int, default=20, help="How many messages to print")
    parser.add_argument("-c", "--conversation_id", default="ALL", help="@user/@group/id of a specific dialogue, or ALL")
    parser.add_argument(
        "-s", "--sort", choices=["ASC", "DESC"], default="ASC",
        help="Ordering by date: ASC - oldest first (default), DESC - newest first",
    )
    args = parser.parse_args()

    try:
        lines = await get_messages(args.conversation_id, args.length, args.sort, **client_kwargs(args))
    except ValueError as exc:
        print(exc, file=sys.stderr)
        return 1

    for line in lines:
        print(line)
    return 0


if __name__ == "__main__":
    sys.exit(asyncio.run(main()))
