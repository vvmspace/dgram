#!/usr/bin/env -S uv run python
"""
commands/search_groups [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session] "query"

Searches for groups by way of Telegram's own global search
(contacts.search), filtering the results down to groups and supergroups
only (broadcast channels are excluded).
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs, emit
from methods.search_groups import search_groups


def _print(rows: list[dict]) -> None:
    for item in rows:
        print(f"{item['id']}\t{item['handle']}\t{item['title']}")


async def main() -> None:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    parser.add_argument("query", help="Search query")
    args = parser.parse_args()

    rows = await search_groups(args.query, **client_kwargs(args))
    emit(rows, args.json_path, _print)


if __name__ == "__main__":
    asyncio.run(main())
