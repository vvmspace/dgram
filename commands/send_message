#!/usr/bin/env -S uv run python
"""
commands/send_message [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session] @user/@group/@me/conversation_id "message"

Sends a message to the specified recipient. If the recipient is a
channel/group the account has not yet joined, it joins first and waits
random(5, 15) seconds before sending.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs
from methods.send_message import send_message


async def main() -> None:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    parser.add_argument("target", help="@user/@group/@me/conversation_id")
    parser.add_argument("message", help="Message text")
    args = parser.parse_args()

    sent = await send_message(args.target, args.message, **client_kwargs(args))
    print(f"[{sent.date}] sent to {args.target}: {sent.text}")


if __name__ == "__main__":
    asyncio.run(main())
