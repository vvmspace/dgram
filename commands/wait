#!/usr/bin/env -S uv run python
"""
commands/wait [-p tdata/--path-to-tdata=tdata] [-s .session/--session=.session] PATTERN [-t 30/--timeout=30] [-c/--conversation_id=] [-m/--message=]

Awaits a fresh message matching PATTERN, for no longer than timeout
seconds. When both conversation_id and message are supplied, it first
sends message to conversation_id and awaits the reply there; otherwise it
awaits a match in any dialogue whatsoever.
"""

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import argparse
import asyncio

from libs.cli import add_client_arguments, client_kwargs, emit
from methods.wait import wait_for_message


async def main() -> int:
    parser = argparse.ArgumentParser()
    add_client_arguments(parser)
    parser.add_argument("pattern", help="Regular expression to search for within the message text")
    parser.add_argument("-t", "--timeout", type=float, default=30, help="Waiting timeout, in seconds")
    parser.add_argument("-c", "--conversation_id", default=None, help="@user/@group/id in which to await/send")
    parser.add_argument("-m", "--message", default=None, help="Message to send before waiting")
    args = parser.parse_args()

    try:
        result = await wait_for_message(
            args.pattern, args.timeout, args.conversation_id, args.message, **client_kwargs(args)
        )
    except asyncio.TimeoutError:
        print(f"No message matching pattern {args.pattern!r} was received within {args.timeout} s.", file=sys.stderr)
        return 1

    emit(result, args.json_path, lambda data: print(f"[{data['date']}] {data['text']}"))
    return 0


if __name__ == "__main__":
    sys.exit(asyncio.run(main()))
